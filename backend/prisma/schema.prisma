generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  password   String?
  authProvider String @default("local") // "local", "google", "apple"
  providerId String?  // ID de Google o Apple
  name       String?
  profilePicture String?
  gender     String?
  role       String   @default("USER")
  isPremium  Boolean  @default(false)
  estiloPersonal String?
  estiloDetalles String?
  age        Int?
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  premiumPlan          String?  // "monthly" o "lifetime"
  isBanned             Boolean  @default(false)
  bannedUntil          DateTime?
  banReason            String?
  friendCode         String?  @unique
  createdAt  DateTime @default(now())
  lastActive DateTime @default(now())
  consultas  Consulta[]
  prendas    PrendaArmario[]
  tickets    Ticket[]
  friendshipsSent     Friendship[] @relation("UserFriendshipsSent")
  friendshipsReceived Friendship[] @relation("UserFriendshipsReceived")
  messagesSent        DirectMessage[] @relation("UserMessagesSent")
  messagesReceived    DirectMessage[] @relation("UserMessagesReceived")
  reportsSent         Report[] @relation("UserReportsSent")
  reportsReceived     Report[] @relation("UserReportsReceived")
}

model Consulta {
  id                 Int      @id @default(autoincrement())
  userId             Int
  ubicacion          String
  clima_json         String
  recomendacion_json String
  createdAt          DateTime @default(now())
  isFavorite         Boolean  @default(false)
  user               User     @relation(fields: [userId], references: [id])
  mensajes           MensajeChat[]
  directMessages     DirectMessage[]
}

model MensajeChat {
  id         Int      @id @default(autoincrement())
  consultaId Int
  rol        String   // "user" or "model"
  contenido  String
  createdAt  DateTime @default(now())
  consulta   Consulta @relation(fields: [consultaId], references: [id])
}

model PrendaArmario {
  id          Int      @id @default(autoincrement())
  userId      Int
  categoria   String   // ej. "top", "bottom", "calzado", "abrigo"
  descripcion String   // ej. "Camiseta básica manga corta"
  color       String?  // ej. "Blanca"
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model Ticket {
  id        Int      @id @default(autoincrement())
  userId    Int
  asunto    String
  mensaje   String
  estado    String   @default("ABIERTO") // ABIERTO | CERRADO
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Friendship {
  id        Int      @id @default(autoincrement())
  user1Id   Int
  user2Id   Int
  status    String   @default("pending") // "pending", "accepted"
  createdAt DateTime @default(now())

  user1     User     @relation("UserFriendshipsSent", fields: [user1Id], references: [id], onDelete: Cascade)
  user2     User     @relation("UserFriendshipsReceived", fields: [user2Id], references: [id], onDelete: Cascade)

  @@unique([user1Id, user2Id])
}

model DirectMessage {
  id          Int      @id @default(autoincrement())
  senderId    Int
  receiverId  Int
  content     String   @db.Text
  outfitId    Int?     // Referencia opcional a Consulta si es un outfit compartido
  createdAt   DateTime @default(now())

  sender      User     @relation("UserMessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User     @relation("UserMessagesReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  outfit      Consulta? @relation(fields: [outfitId], references: [id], onDelete: Cascade)
}

model Report {
  id          Int      @id @default(autoincrement())
  reporterId  Int
  reportedId  Int
  reason      String
  description String?
  status      String   @default("pending") // pending, reviewed, resolved
  createdAt   DateTime @default(now())

  reporter    User     @relation("UserReportsSent", fields: [reporterId], references: [id], onDelete: Cascade)
  reported    User     @relation("UserReportsReceived", fields: [reportedId], references: [id], onDelete: Cascade)

  @@unique([reporterId, reportedId])
}
