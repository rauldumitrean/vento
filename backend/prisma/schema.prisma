generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  password   String?
  authProvider String @default("local") // "local", "google", "apple"
  providerId String?  // ID de Google o Apple
  name       String?
  gender     String?
  role       String   @default("USER")
  isPremium  Boolean  @default(false)
  estiloPersonal String?
  estiloDetalles String?
  age        Int?
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  premiumPlan          String?  // "monthly" o "lifetime"
  isBanned             Boolean  @default(false)
  bannedUntil          DateTime?
  banReason            String?
  createdAt  DateTime @default(now())
  lastActive DateTime @default(now())
  consultas  Consulta[]
  prendas    PrendaArmario[]
  tickets    Ticket[]
}

model Consulta {
  id                 Int      @id @default(autoincrement())
  userId             Int
  ubicacion          String
  clima_json         String
  recomendacion_json String
  createdAt          DateTime @default(now())
  isFavorite         Boolean  @default(false)
  user               User     @relation(fields: [userId], references: [id])
  mensajes           MensajeChat[]
}

model MensajeChat {
  id         Int      @id @default(autoincrement())
  consultaId Int
  rol        String   // "user" or "model"
  contenido  String
  createdAt  DateTime @default(now())
  consulta   Consulta @relation(fields: [consultaId], references: [id])
}

model PrendaArmario {
  id          Int      @id @default(autoincrement())
  userId      Int
  categoria   String   // ej. "top", "bottom", "calzado", "abrigo"
  descripcion String   // ej. "Camiseta básica manga corta"
  color       String?  // ej. "Blanca"
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model Ticket {
  id        Int      @id @default(autoincrement())
  userId    Int
  asunto    String
  mensaje   String
  estado    String   @default("ABIERTO") // ABIERTO | CERRADO
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
